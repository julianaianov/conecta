#
# URL do gateway da API (nginx → auth/user/post services).
# - Deixe VAZIO para rodar 100% em modo demo (dados em memória do Recreio).
# - Defina para habilitar o modo HÍBRIDO: tenta a API real e cai para o demo
#   automaticamente se a rede falhar (espelha o useDemoFallback do app Flutter).
#
# Ex. local (docker-compose na raiz do repo): NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=
